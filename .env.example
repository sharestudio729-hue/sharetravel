# ══════════════════════════════════════════════════════
#   CampSaaS - Environment Variables
#   Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════

# ─── App ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────
# For Docker Compose:
POSTGRES_DB=campsaas
POSTGRES_USER=campsaas
POSTGRES_PASSWORD=changeme_strong_password

# For direct connection (used by NestJS):
DATABASE_URL=postgresql://campsaas:changeme_strong_password@localhost:5432/campsaas

# ─── Redis ────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis_password
REDIS_URL=redis://:changeme_redis_password@localhost:6379

# ─── JWT (generate with: openssl rand -hex 64) ────────
JWT_ACCESS_SECRET=your_64_char_hex_secret_here
JWT_REFRESH_SECRET=your_other_64_char_hex_secret_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ─── Stripe (get from dashboard.stripe.com) ───────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create in Stripe dashboard)
STRIPE_STARTER_MONTHLY_PRICE_ID=price_...
STRIPE_STARTER_YEARLY_PRICE_ID=price_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=price_...
STRIPE_ENTERPRISE_YEARLY_PRICE_ID=price_...

# ─── OpenAI ───────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ─── WhatsApp Cloud API ───────────────────────────────
# From Meta Business → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_BUSINESS_ACCOUNT_ID=0987654321
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token_here

# ─── Email (SMTP) ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
SMTP_FROM=CampSaaS <noreply@yourdomain.com>

# ─── Frontend (Next.js public vars) ──────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:4000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
